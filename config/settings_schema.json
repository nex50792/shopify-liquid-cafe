[
  {
    "name": "theme_info",
    "theme_name": "Mame Coffee",
    "theme_version": "0.1.0",
    "theme_author": "shopify-liquid-cafe",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "assistant_n4",
        "label": "t:labels.body_font"
      },
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "default": "assistant_n4",
        "label": "t:labels.heading_font"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "default": "#FBF8F3",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#2B1810",
        "label": "t:labels.foreground"
      },
      {
        "type": "color",
        "id": "accent_primary_color",
        "default": "#6B3410",
        "label": "t:labels.accent_primary"
      },
      {
        "type": "color",
        "id": "accent_secondary_color",
        "default": "#D4A574",
        "label": "t:labels.accent_secondary"
      },
      {
        "type": "color",
        "id": "surface_color",
        "default": "#F5EFE4",
        "label": "t:labels.surface"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 2
      }
    ]
  }
