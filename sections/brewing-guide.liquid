{%- liquid
  assign heading = section.settings.heading | default: 'コーヒーの淹れ方'
  assign eyebrow = section.settings.eyebrow
-%}

<section class="brewing" data-section-id="{{ section.id }}">
  <div class="brewing__header">
    {%- if eyebrow != blank -%}
      <span class="eyebrow">{{ eyebrow }}</span>
    {%- endif -%}
    <h2 class="brewing__heading">{{ heading }}</h2>
  </div>

  {%- if section.blocks.size > 0 -%}
    <ol class="brewing__steps">
      {%- for block in section.blocks -%}
        <li class="brewing__step" {{ block.shopify_attributes }}>
          <div class="brewing__step-number" aria-hidden="true">
            {{- forloop.index | prepend: '0' | slice: -2, 2 -}}
          </div>
          <div class="brewing__step-body">
            <h3 class="brewing__step-title">{{ block.settings.heading }}</h3>
            <p class="brewing__step-text">{{ block.settings.text }}</p>
          </div>
        </li>
      {%- endfor -%}
    </ol>
  {%- endif -%}
</section>

{% stylesheet %}
  .brewing {
    padding-block: var(--space-2xl);
  }

  .brewing__header {
    text-align: center;
    margin-block-end: var(--space-xl);
  }

  .brewing__steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-lg);
    max-width: 44rem;
    margin-inline: auto;
  }

  .brewing__step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-md);
    align-items: start;
    padding-block-end: var(--space-md);
    border-block-end: 1px solid color-mix(in oklab, var(--color-foreground) 12%, transparent);
  }

  .brewing__step:last-child {
    border-block-end: none;
  }

  .brewing__step-number {
    font-family: var(--font-heading--family);
    font-size: 2.5rem;
    line-height: 1;
    color: var(--color-accent-primary);
    font-variant-numeric: tabular-nums;
  }

  .brewing__step-title {
    margin-block-end: var(--space-xs);
    font-size: 1.25rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.brewing_guide.name",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "ハンドドリップ"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "淹れ方"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "t:sections.brewing_guide.blocks.step.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.heading"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:labels.text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.brewing_guide.presets.default",
      "category": "Coffee",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "heading": "湯を 92°C まで沸かす",
            "text": "浄水した水を沸騰させ、火から下ろして 30 秒ほど落ち着かせます。"
          }
        },
        {
          "type": "step",
          "settings": {
            "heading": "豆を 15g、中挽きで挽く",
            "text": "食塩より粗く、天然塩より細かい粒度を目安に。"
          }
        },
        {
          "type": "step",
          "settings": {
            "heading": "30 秒蒸らす",
            "text": "50g の湯を注ぎ、泡が落ち着くまで待ちます。"
          }
        },
        {
          "type": "step",
          "settings": {
            "heading": "残りの湯 200g をゆっくり注ぐ",
            "text": "抽出時間の目安は合計 3 分〜3 分 30 秒です。"
          }
        }
      ]
    }
  ]
}
{% endschema %}
